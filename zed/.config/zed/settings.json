// defaults: https://github.com/zed-industries/zed/blob/main/assets/settings/default.json
{
  "agent": {
    "default_model": {
      "enable_thinking": false,
      "model": "gemma4:e4b",
      "provider": "ollama",
    },
    "dock": "right",
    "enabled": true,
    "favorite_models": [],
    "model_parameters": [],
    "show_turn_stats": true,
    "thinking_display": "always_expanded",
  },
  "agent_servers": {
    "opencode": {
      "type": "registry",
    },
  },
  "auto_install_extensions": {
    "catppuccin": true,
    "catppuccin-icons": true,
    "cucumber": true,
    "dockerfile": true,
    "docker-compose": false,
    "editorconfig": true,
    "git-firefly": true,
    "html": true,
    "java": true,
    "lua": true,
    "make": true,
    "mermaid": true,
    "ruby": true,
    "sql": true,
    "toml": true,
    "vue": true,
    "xml": true,
  },
  "auto_update": true,
  "base_keymap": "JetBrains",
  "buffer_font_family": "JetBrainsMonoNL Nerd Font",
  "buffer_font_features": {
    "calt": false,
  },
  "buffer_font_size": 14.0,
  "buffer_font_weight": 300.0,
  "buffer_line_height": "comfortable",
  "cli_default_open_behavior": "new_window",
  "code_lens": "on",
  "colorize_brackets": true,
  "completion_menu_item_kind": "symbol",
  "confirm_quit": true,
  "current_line_highlight": "all",
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "ensure_final_newline_on_save": true,
  "file_finder": {
    "include_ignored": "all",
  },
  "file_scan_exclusions": [],
  "format_on_save": "on",
  "git_panel": {
    "collapse_untracked_diff": false,
    "dock": "left",
    "file_icons": true,
    "sort_by_path": true,
    "show_count_badge": true,
    "tree_view": true,
  },
  "go_to_definition_scroll_strategy": "top",
  "gutter": {
    "line_numbers": true,
  },
  "icon_theme": {
    "dark": "Catppuccin Mocha",
    "light": "Catppuccin Latte",
    "mode": "dark",
  },
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
  },
  "languages": {
    "Make": {
      "hard_tabs": true,
    },
  },
  "minimap": {
    "show": "never",
  },
  "outline_panel": {
    "dock": "left",
  },
  "preview_tabs": {
    "enabled": false,
  },
  "project_panel": {
    "diagnostic_badges": true,
    "dock": "left",
    "entry_spacing": "comfortable",
    "hide_gitignore": false,
    "hide_hidden": false,
    "git_status": true,
    "git_status_indicator": true,
    "starts_open": true,
  },
  "relative_line_numbers": "disabled",
  "remove_trailing_whitespace_on_save": true,
  "scroll_beyond_last_line": "one_page",
  "session": {
    "trust_all_worktrees": true,
  },
  "soft_wrap": "editor_width",
  "status_bar": {
    "line_endings_button": true,
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "show_diagnostics": "all",
  },
  "terminal": {
    "font_family": "JetBrainsMono Nerd Font",
    "font_size": 14.0,
    "font_weight": 300.0,
  },
  "theme": {
    "dark": "Catppuccin Mocha",
    "light": "Catppuccin Latte",
    "mode": "dark",
  },
  "title_bar": {
    "show_branch_status_icon": true,
  },
  "toolbar": {
    "code_actions": true,
  },
  "ui_font_size": 16,
  "use_auto_surround": true,
}
